rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUserDbState(data) {
      return data.keys().hasAll(['participants', 'sessions', 'attendance', 'lastUpdated'])
        && data.keys().size() <= 9
        && data.participants is list
        && data.sessions is list
        && data.attendance is map
        && data.lastUpdated is string
        && data.lastUpdated.size() <= 128
        && (data.get('emailedSessionDates', []) is list)
        && (data.get('dismissedEmailDates', []) is list)
        && (data.get('lastEmailedSessionDate', null) == null || data.get('lastEmailedSessionDate', null) is string)
        && (data.get('staffEmailRecipient', null) == null || data.get('staffEmailRecipient', null) is string)
        && (data.get('isAutomaticEmailEnabled', true) == null || data.get('isAutomaticEmailEnabled', true) is bool);
    }

    // Secure user-specific sub-paths for participants state cache syncing
    match /users/{userId}/data/metrics {
      allow read: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserDbState(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserDbState(incoming());
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
